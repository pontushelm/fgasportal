generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum InstallationEventType {
  INSPECTION
  LEAK
  REFILL
  SERVICE
}

enum DocumentType {
  INSPECTION_REPORT
  SERVICE_REPORT
  LEAK_REPORT
  PHOTO
  AUTHORITY_DOCUMENT
  OTHER
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  CONTRACTOR
}

model Company {
  id        String   @id @default(cuid())
  name      String
  orgNumber String   @unique
  organizationNumber String?
  contactPerson String?
  contactEmail String?
  contactPhone String?
  address   String?
  postalCode String?
  city String?
  billingEmail String?
  invoiceReference String?
  billingAddress String?
  vatNumber String?
  eInvoiceId String?
  /// Deprecated: retained for backward compatibility, not edited in company settings.
  supervisoryAuthority String?
  sendInspectionRemindersToContractors Boolean @default(false)
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)
  planType  String   @default("free")

  users         User[]
  memberships   CompanyMembership[]
  properties    Property[]
  installations Installation[]
  invitations   Invitation[]
  installationDocuments InstallationDocument[]
  activityLogs ActivityLog[]
  savedFilters SavedFilter[]

  @@map("companies")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(ADMIN)
  themePreference String @default("light")
  notifyAssignmentEmails Boolean @default(true)
  notifyInspectionReminderEmails Boolean @default(true)
  notifyDocumentEmails Boolean @default(true)
  notifyAnnualReportDeadlineEmails Boolean @default(true)
  notifyLeakEmails Boolean @default(true)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships CompanyMembership[]

  createdInstallations Installation[] @relation("CreatedBy")
  updatedInstallations Installation[] @relation("UpdatedBy")
  assignedInstallations Installation[] @relation("AssignedContractor")
  sentInvitations      Invitation[]   @relation("InvitedBy")
  installationEvents   InstallationEvent[]
  uploadedInstallationDocuments InstallationDocument[]
  activityLogs ActivityLog[]
  savedFilters SavedFilter[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model CompanyMembership {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
  @@map("company_memberships")
}

model Invitation {
  id              String    @id @default(cuid())
  email           String
  role            String
  token           String    @unique
  acceptedAt      DateTime?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  invitedByUserId String
  invitedByUser   User   @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@map("invitations")
}

model Installation {
  id                String   @id @default(cuid())
  name              String
  location          String
  equipmentId       String?
  serialNumber      String?
  propertyName      String?
  equipmentType     String?
  operatorName      String?
  refrigerantType   String
  refrigerantAmount Float
  hasLeakDetectionSystem Boolean @default(false)
  installationDate  DateTime
  lastInspection    DateTime?
  inspectionIntervalMonths Int?
  nextInspection    DateTime?
  notes             String?
  isActive          Boolean  @default(true)
  archivedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  updatedById String
  updatedBy   User @relation("UpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  assignedContractorId String?
  assignedContractor   User? @relation("AssignedContractor", fields: [assignedContractorId], references: [id], onDelete: SetNull)

  inspections Inspection[]
  reminderLogs ReminderLog[]
  events InstallationEvent[]
  documents InstallationDocument[]
  activityLogs ActivityLog[]

  @@map("installations")
}

model Property {
  id                  String   @id @default(cuid())
  companyId           String
  name                String
  address             String?
  postalCode          String?
  city                String?
  municipality        String?
  propertyDesignation String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  installations Installation[]

  @@index([companyId])
  @@index([municipality])
  @@map("properties")
}

model Inspection {
  id             String   @id @default(cuid())
  inspectionDate DateTime
  inspectorName  String
  status         String?
  notes          String?
  findings       String?
  nextDueDate    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  installationId String
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@map("inspections")
}

model ReminderLog {
  id             String   @id @default(cuid())
  installationId String
  userId         String?
  email          String
  type           String
  reminderKey    String
  sentAt         DateTime @default(now())

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([installationId, email, type, reminderKey])
  @@index([installationId])
  @@index([email])
  @@index([sentAt])
  @@map("reminder_logs")
}

model InstallationEvent {
  id                 String                @id @default(cuid())
  installationId     String
  installation       Installation          @relation(fields: [installationId], references: [id], onDelete: Cascade)
  date               DateTime
  type               InstallationEventType
  refrigerantAddedKg Float?
  notes              String?
  createdById        String?
  createdBy          User?                 @relation(fields: [createdById], references: [id])
  createdAt          DateTime              @default(now())
  documents          InstallationDocument[]

  @@index([installationId])
  @@map("installation_events")
}

model InstallationDocument {
  id               String       @id @default(cuid())
  installationId   String
  eventId          String?
  companyId        String
  uploadedById     String
  fileName         String
  originalFileName String
  fileUrl          String
  blobPath         String
  mimeType         String
  sizeBytes        Int
  documentType     DocumentType
  description      String?
  createdAt        DateTime     @default(now())

  installation Installation       @relation(fields: [installationId], references: [id], onDelete: Cascade)
  event        InstallationEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy   User               @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([installationId])
  @@index([eventId])
  @@index([companyId])
  @@index([uploadedById])
  @@map("installation_documents")
}

model ActivityLog {
  id             String   @id @default(cuid())
  companyId      String
  installationId String?
  userId         String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  installation Installation? @relation(fields: [installationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([installationId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model SavedFilter {
  id          String   @id @default(cuid())
  name        String
  userId      String
  companyId   String
  page        String
  queryParams Json
  createdAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([page])
  @@map("saved_filters")
}
