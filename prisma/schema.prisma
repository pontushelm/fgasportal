generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum InstallationEventType {
  INSPECTION
  LEAK
  REFILL
  SERVICE
  REPAIR
  RECOVERY
  REFRIGERANT_CHANGE
}

enum DocumentType {
  INSPECTION_REPORT
  SERVICE_REPORT
  LEAK_REPORT
  PHOTO
  AUTHORITY_DOCUMENT
  OTHER
}

enum DocumentStorageProvider {
  VERCEL_BLOB
}

enum DocumentCategory {
  INSPECTION_REPORT
  SERVICE_REPORT
  LEAK_REPORT
  PHOTO
  AUTHORITY_DOCUMENT
  SCRAP_CERTIFICATE
  PERSONAL_FGAS_CERTIFICATE
  PROPERTY_DOCUMENT
  SERVICE_ORGANIZATION_CERTIFICATE
  REPORT_OUTPUT
  CUSTOMER_EXPORT
  AUDIT_EVIDENCE
  OTHER
}

enum DocumentSource {
  USER_UPLOAD
  SYSTEM_GENERATED
  SIGNED_REPORT_ARTIFACT
  IMPORT
}

enum DocumentStatus {
  ACTIVE
  REPLACED
  DELETED
  QUARANTINED
}

enum DocumentVisibility {
  COMPANY_INTERNAL
  SERVICE_PARTNER_VISIBLE
  OWNER_ADMIN_ONLY
  SYSTEM_ONLY
}

enum DocumentRetentionPolicy {
  STANDARD
  RETAINED
  IMMUTABLE
  TEMPORARY
  LEGAL_HOLD
}

enum DocumentLinkEntityType {
  INSTALLATION
  INSTALLATION_EVENT
  PROPERTY
  SERVICE_ORGANIZATION
  CERTIFICATION_RECORD
  SIGNED_REPORT_ARTIFACT
  COMPANY
  REPORT_SCOPE
  CUSTOMER_EXPORT
}

enum DocumentLinkRole {
  ATTACHMENT
  EVIDENCE
  SCRAP_CERTIFICATE
  CERTIFICATE
  REPORT_OUTPUT
  SUPPORTING_FILE
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  CONTRACTOR
}

enum FeedbackType {
  BUG
  IMPROVEMENT
  QUESTION
  OTHER
}

enum ServiceOrganizationRole {
  ADMIN
  TECHNICIAN
}

enum CertificationSubjectType {
  SERVICE_ORGANIZATION
  TECHNICIAN
  COMPANY
}

enum CertificationType {
  COMPANY_FGAS
  PERSONAL_FGAS
  OTHER
}

enum CertificationRecordStatus {
  ACTIVE
  EXPIRED
  REPLACED
  REVOKED
  DELETED
}

enum CertificationVerificationStatus {
  UNVERIFIED
  SELF_DECLARED
  VERIFIED
}

enum SignedReportType {
  ANNUAL_FGAS
  CLIMATE
  COMPLIANCE
  AUDIT
  CUSTOMER_EXPORT
}

enum SignedReportScopeType {
  PROPERTY
  MUNICIPALITY
  COMPANY
  CUSTOM
}

enum SignedReportArtifactStatus {
  STORED
  METADATA_ONLY
  SUPERSEDED
  FAILED
  DELETED
}

enum SignedReportSigningMethod {
  FGASPORTAL_ELECTRONIC
}

enum NotificationDigestType {
  DAILY
  WEEKLY
}

model Company {
  id                                   String   @id @default(cuid())
  name                                 String
  orgNumber                            String   @unique
  organizationNumber                   String?
  contactPerson                        String?
  contactEmail                         String?
  contactPhone                         String?
  address                              String?
  postalCode                           String?
  city                                 String?
  billingEmail                         String?
  invoiceReference                     String?
  billingAddress                       String?
  vatNumber                            String?
  eInvoiceId                           String?
  /// Deprecated: retained for backward compatibility, not edited in company settings.
  supervisoryAuthority                 String?
  sendInspectionRemindersToContractors Boolean  @default(false)
  sendCertificateReminders             Boolean  @default(true)
  sendAnnualReportReminders            Boolean  @default(true)
  phone                                String?
  createdAt                            DateTime @default(now())
  updatedAt                            DateTime @updatedAt
  isActive                             Boolean  @default(true)
  planType                             String   @default("free")

  users                   User[]
  memberships             CompanyMembership[]
  properties              Property[]
  installations           Installation[]
  invitations             Invitation[]
  installationDocuments   InstallationDocument[]
  activityLogs            ActivityLog[]
  savedFilters            SavedFilter[]
  signedReportArtifacts   SignedReportArtifact[]
  signedAnnualFgasReports SignedAnnualFgasReport[]
  servicePartnerCompanies ServicePartnerCompany[]
  companyServiceOrganizations CompanyServiceOrganization[]
  feedback                Feedback[]
  documents               Document[]
  documentLinks           DocumentLink[]
  certificationRecords    CertificationRecord[]
  notificationDigestLogs  NotificationDigestLog[]

  @@map("companies")
}

model User {
  id                               String   @id @default(cuid())
  email                            String   @unique
  name                             String
  phone                            String?
  certificationNumber              String?
  certificationIssuer              String?
  certificationValidUntil          DateTime?
  certificationCategory            String?
  password                         String
  role                             UserRole @default(ADMIN)
  themePreference                  String   @default("light")
  notifyAssignmentEmails           Boolean  @default(true)
  notifyInspectionReminderEmails   Boolean  @default(true)
  notifyDocumentEmails             Boolean  @default(true)
  notifyAnnualReportDeadlineEmails Boolean  @default(true)
  notifyLeakEmails                 Boolean  @default(true)
  isActive                         Boolean  @default(true)
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt

  companyId   String
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships CompanyMembership[]

  createdInstallations          Installation[]           @relation("CreatedBy")
  updatedInstallations          Installation[]           @relation("UpdatedBy")
  assignedInstallations         Installation[]           @relation("AssignedContractor")
  sentInvitations               Invitation[]             @relation("InvitedBy")
  installationEvents            InstallationEvent[]
  uploadedInstallationDocuments InstallationDocument[]
  activityLogs                  ActivityLog[]
  savedFilters                  SavedFilter[]
  signedReportArtifacts         SignedReportArtifact[]
  signedAnnualFgasReports       SignedAnnualFgasReport[]
  passwordResetTokens           PasswordResetToken[]
  feedback                      Feedback[]
  serviceOrganizationMemberships ServiceOrganizationMembership[]
  uploadedDocuments             Document[]               @relation("UploadedDocuments")
  deletedDocuments              Document[]               @relation("DeletedDocuments")
  linkedDocuments               DocumentLink[]           @relation("LinkedDocuments")
  certificationRecords          CertificationRecord[]    @relation("CertificationSubjectUser")
  verifiedCertificationRecords  CertificationRecord[]    @relation("CertificationVerifiedBy")
  createdCertificationRecords   CertificationRecord[]    @relation("CertificationCreatedBy")
  updatedCertificationRecords   CertificationRecord[]    @relation("CertificationUpdatedBy")
  notificationDigestLogs        NotificationDigestLog[]

  @@map("users")
}

model NotificationDigestLog {
  id           String                 @id @default(cuid())
  companyId    String
  userId       String?
  recipientKey String
  digestDate   DateTime
  digestType   NotificationDigestType
  totalItems   Int
  sentAt       DateTime
  createdAt    DateTime               @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([companyId, recipientKey, digestDate, digestType])
  @@index([companyId])
  @@index([userId])
  @@index([digestDate])
  @@map("notification_digest_logs")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model CompanyMembership {
  id                        String    @id @default(cuid())
  userId                    String
  companyId                 String
  role                      UserRole
  isActive                  Boolean   @default(true)
  isCertifiedCompany        Boolean   @default(false)
  certificationNumber       String?
  certificationValidUntil   DateTime?
  certificationOrganization String?
  servicePartnerCompanyId   String?
  isServicePartnerAdmin     Boolean   @default(false)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  servicePartnerCompany ServicePartnerCompany? @relation(fields: [servicePartnerCompanyId], references: [id], onDelete: SetNull)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
  @@index([servicePartnerCompanyId])
  @@map("company_memberships")
}

model ServicePartnerCompany {
  id                 String   @id @default(cuid())
  companyId          String
  /// Transitional bridge to the future global servicepartner identity.
  /// Keep customer-scoped ServicePartnerCompany behavior until installation assignment is migrated.
  serviceOrganizationId String?
  name               String
  organizationNumber String?
  contactEmail       String?
  phone              String?
  certificateNumber  String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceOrganization ServiceOrganization? @relation(fields: [serviceOrganizationId], references: [id], onDelete: SetNull)
  memberships CompanyMembership[]
  invitations Invitation[]
  assignedInstallations Installation[] @relation("AssignedServicePartnerCompany")

  @@unique([companyId, name])
  @@index([companyId])
  @@index([serviceOrganizationId])
  @@map("service_partner_companies")
}

model ServiceOrganization {
  id                 String   @id @default(cuid())
  name               String
  organizationNumber String?
  contactEmail       String?
  phone              String?
  certificateNumber  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  legacyServicePartnerCompanies ServicePartnerCompany[]
  memberships                   ServiceOrganizationMembership[]
  companyLinks                  CompanyServiceOrganization[]
  invitations                   Invitation[]
  certificationRecords          CertificationRecord[]

  @@index([organizationNumber])
  @@map("service_organizations")
}

model CertificationRecord {
  id                    String                          @id @default(cuid())
  serviceOrganizationId String?
  userId                String?
  companyId             String
  subjectType           CertificationSubjectType
  certificateType       CertificationType
  certificateNumber     String
  issuer                String?
  category              String?
  validFrom             DateTime?
  validUntil            DateTime?
  status                CertificationRecordStatus       @default(ACTIVE)
  verificationStatus    CertificationVerificationStatus @default(UNVERIFIED)
  verifiedAt            DateTime?
  verifiedByUserId      String?
  documentId            String?
  notes                 String?
  createdByUserId       String?
  updatedByUserId       String?
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceOrganization ServiceOrganization? @relation(fields: [serviceOrganizationId], references: [id], onDelete: Cascade)
  user                User?                @relation("CertificationSubjectUser", fields: [userId], references: [id], onDelete: Cascade)
  verifiedBy          User?                @relation("CertificationVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  createdBy           User?                @relation("CertificationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy           User?                @relation("CertificationUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([serviceOrganizationId])
  @@index([userId])
  @@index([subjectType])
  @@index([certificateType])
  @@index([status])
  @@index([validUntil])
  @@index([documentId])
  @@map("certification_records")
}

model ServiceOrganizationMembership {
  id                    String                  @id @default(cuid())
  serviceOrganizationId String
  userId                String
  role                  ServiceOrganizationRole
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())

  serviceOrganization ServiceOrganization @relation(fields: [serviceOrganizationId], references: [id], onDelete: Cascade)
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([serviceOrganizationId, userId])
  @@index([userId])
  @@map("service_organization_memberships")
}

model CompanyServiceOrganization {
  id                    String   @id @default(cuid())
  companyId             String
  serviceOrganizationId String
  displayName           String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())

  company             Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceOrganization ServiceOrganization @relation(fields: [serviceOrganizationId], references: [id], onDelete: Cascade)

  @@unique([companyId, serviceOrganizationId])
  @@index([serviceOrganizationId])
  @@map("company_service_organizations")
}

model Invitation {
  id         String    @id @default(cuid())
  email      String
  role       String
  token      String    @unique
  acceptedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  servicePartnerCompanyId String?
  servicePartnerCompany   ServicePartnerCompany? @relation(fields: [servicePartnerCompanyId], references: [id], onDelete: SetNull)
  serviceOrganizationId String?
  serviceOrganization   ServiceOrganization? @relation(fields: [serviceOrganizationId], references: [id], onDelete: SetNull)
  isServicePartnerAdminInvite Boolean @default(false)

  invitedByUserId String
  invitedByUser   User   @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@index([servicePartnerCompanyId])
  @@index([serviceOrganizationId])
  @@map("invitations")
}

model Installation {
  id                            String    @id @default(cuid())
  name                          String
  location                      String
  equipmentId                   String?
  serialNumber                  String?
  propertyName                  String?
  equipmentType                 String?
  operatorName                  String?
  refrigerantType               String
  refrigerantAmount             Float
  hasLeakDetectionSystem        Boolean   @default(false)
  installationDate              DateTime?
  lastInspection                DateTime?
  inspectionIntervalMonths      Int?
  nextInspection                DateTime?
  notes                         String?
  isActive                      Boolean   @default(true)
  archivedAt                    DateTime?
  scrappedAt                    DateTime?
  scrappedByCompanyMembershipId String?
  scrapComment                  String?
  scrapCertificateUrl           String?
  scrapCertificateFileName      String?
  scrapCertificateBlobPath      String?
  scrapServicePartnerId         String?
  recoveredRefrigerantKg        Float?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  updatedById String
  updatedBy   User   @relation("UpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  assignedContractorId String?
  assignedContractor   User?   @relation("AssignedContractor", fields: [assignedContractorId], references: [id], onDelete: SetNull)

  assignedServicePartnerCompanyId String?
  assignedServicePartnerCompany   ServicePartnerCompany? @relation("AssignedServicePartnerCompany", fields: [assignedServicePartnerCompanyId], references: [id], onDelete: SetNull)

  inspections  Inspection[]
  reminderLogs ReminderLog[]
  events       InstallationEvent[]
  documents    InstallationDocument[]
  activityLogs ActivityLog[]

  @@index([assignedServicePartnerCompanyId])
  @@map("installations")
}

model Property {
  id                  String   @id @default(cuid())
  companyId           String
  name                String
  address             String?
  postalCode          String?
  city                String?
  municipality        String?
  propertyDesignation String?
  internalReference   String?
  description         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  installations Installation[]

  @@index([companyId])
  @@index([municipality])
  @@map("properties")
}

model Inspection {
  id             String    @id @default(cuid())
  inspectionDate DateTime
  inspectorName  String
  status         String?
  notes          String?
  findings       String?
  nextDueDate    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  installationId String
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@map("inspections")
}

model ReminderLog {
  id             String   @id @default(cuid())
  installationId String
  userId         String?
  email          String
  type           String
  reminderKey    String
  sentAt         DateTime @default(now())

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([installationId, email, type, reminderKey])
  @@index([installationId])
  @@index([email])
  @@index([sentAt])
  @@map("reminder_logs")
}

model InstallationEvent {
  id                      String                 @id @default(cuid())
  installationId          String
  installation            Installation           @relation(fields: [installationId], references: [id], onDelete: Cascade)
  date                    DateTime
  type                    InstallationEventType
  refrigerantAddedKg      Float?
  previousRefrigerantType String?
  newRefrigerantType      String?
  previousAmountKg        Float?
  newAmountKg             Float?
  recoveredAmountKg       Float?
  notes                   String?
  supersededAt            DateTime?
  supersededByEventId     String?
  supersededReason        String?
  supersededByUserId      String?
  createdById             String?
  createdBy               User?                  @relation(fields: [createdById], references: [id])
  createdAt               DateTime               @default(now())
  documents               InstallationDocument[]

  @@index([installationId])
  @@index([supersededAt])
  @@map("installation_events")
}

model InstallationDocument {
  id               String       @id @default(cuid())
  installationId   String
  eventId          String?
  companyId        String
  uploadedById     String
  fileName         String
  originalFileName String
  fileUrl          String
  blobPath         String
  mimeType         String
  sizeBytes        Int
  documentType     DocumentType
  description      String?
  createdAt        DateTime     @default(now())

  installation Installation       @relation(fields: [installationId], references: [id], onDelete: Cascade)
  event        InstallationEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy   User               @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([installationId])
  @@index([eventId])
  @@index([companyId])
  @@index([uploadedById])
  @@map("installation_documents")
}

model Document {
  id                           String                  @id @default(cuid())
  companyId                    String
  uploadedByUserId             String?
  originalFileName             String
  fileName                     String
  contentType                  String
  sizeBytes                    Int
  sha256                       String?
  storageProvider              DocumentStorageProvider @default(VERCEL_BLOB)
  storageKey                   String
  storageBucket                String?
  category                     DocumentCategory
  source                       DocumentSource          @default(USER_UPLOAD)
  status                       DocumentStatus          @default(ACTIVE)
  visibility                   DocumentVisibility      @default(COMPANY_INTERNAL)
  retentionPolicy              DocumentRetentionPolicy @default(STANDARD)
  description                  String?
  metadata                     Json?
  replacedByDocumentId         String?
  replacedAt                   DateTime?
  deletedAt                    DateTime?
  deletedByUserId              String?
  deletionReason               String?
  legacyInstallationDocumentId String?                 @unique
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt

  company            Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy         User?          @relation("UploadedDocuments", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  deletedBy          User?          @relation("DeletedDocuments", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  replacedByDocument Document?      @relation("DocumentReplacement", fields: [replacedByDocumentId], references: [id], onDelete: SetNull)
  replacesDocuments  Document[]     @relation("DocumentReplacement")
  links              DocumentLink[]

  @@index([companyId])
  @@index([uploadedByUserId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@index([replacedByDocumentId])
  @@index([deletedByUserId])
  @@map("documents")
}

model DocumentLink {
  id             String                 @id @default(cuid())
  companyId      String
  documentId     String
  entityType     DocumentLinkEntityType
  entityId       String
  role           DocumentLinkRole       @default(ATTACHMENT)
  linkedAt       DateTime               @default(now())
  linkedByUserId String?

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  linkedBy User?    @relation("LinkedDocuments", fields: [linkedByUserId], references: [id], onDelete: SetNull)

  @@unique([documentId, entityType, entityId, role])
  @@index([companyId])
  @@index([documentId])
  @@index([entityType, entityId])
  @@index([linkedByUserId])
  @@map("document_links")
}

model ActivityLog {
  id             String   @id @default(cuid())
  companyId      String
  installationId String?
  userId         String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  installation Installation? @relation(fields: [installationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  signedReportArtifactsSigned SignedReportArtifact[] @relation("SignedReportArtifactSignedActivityLog")
  signedReportArtifactsExported SignedReportArtifact[] @relation("SignedReportArtifactExportActivityLog")

  @@index([companyId])
  @@index([installationId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model SavedFilter {
  id          String   @id @default(cuid())
  name        String
  userId      String
  companyId   String
  page        String
  queryParams Json
  createdAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([page])
  @@map("saved_filters")
}

model SignedReportArtifact {
  id                     String                    @id @default(cuid())
  companyId              String
  signedByUserId         String?
  reportType             SignedReportType
  scopeType              SignedReportScopeType
  scopeId                String?
  scopeLabel             String?
  reportYear             Int?
  periodStart            DateTime?
  periodEnd              DateTime?
  status                 SignedReportArtifactStatus @default(STORED)
  signingMethod          SignedReportSigningMethod @default(FGASPORTAL_ELECTRONIC)
  signerName             String
  signerEmail            String?
  signerRole             String?
  signingText            String?
  signedAt               DateTime
  pdfStorageKey          String?
  pdfFileName            String?
  pdfContentType         String                    @default("application/pdf")
  pdfSizeBytes           Int?
  pdfSha256              String?
  snapshot               Json?
  snapshotSha256         String?
  snapshotVersion        Int?
  snapshotSchema         String
  templateVersion        String
  rendererVersion        String?
  supersedesArtifactId   String?
  supersededByArtifactId String?
  correctionReason       String?
  supersededAt           DateTime?
  signedActivityLogId    String?
  exportActivityLogId    String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  company              Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  signedByUser         User?                  @relation(fields: [signedByUserId], references: [id], onDelete: SetNull)
  supersedesArtifact   SignedReportArtifact?  @relation("SignedReportArtifactSupersedes", fields: [supersedesArtifactId], references: [id], onDelete: SetNull)
  supersededArtifacts  SignedReportArtifact[] @relation("SignedReportArtifactSupersedes")
  supersededByArtifact SignedReportArtifact?  @relation("SignedReportArtifactSupersededBy", fields: [supersededByArtifactId], references: [id], onDelete: SetNull)
  supersedingArtifacts SignedReportArtifact[] @relation("SignedReportArtifactSupersededBy")
  signedActivityLog    ActivityLog?           @relation("SignedReportArtifactSignedActivityLog", fields: [signedActivityLogId], references: [id], onDelete: SetNull)
  exportActivityLog    ActivityLog?           @relation("SignedReportArtifactExportActivityLog", fields: [exportActivityLogId], references: [id], onDelete: SetNull)
  annualFgasReport     SignedAnnualFgasReport?

  @@index([companyId])
  @@index([signedByUserId])
  @@index([reportType])
  @@index([reportYear])
  @@index([scopeId])
  @@index([createdAt])
  @@index([status])
  @@index([signedActivityLogId])
  @@index([exportActivityLogId])
  @@map("signed_report_artifacts")
}

model SignedAnnualFgasReport {
  id                 String   @id @default(cuid())
  companyId          String
  userId             String?
  artifactId         String?  @unique
  reportYear         Int
  municipality       String?
  propertyId         String?
  propertyName       String?
  signerName         String
  signerRole         String
  signingDate        DateTime
  comment            String?
  readinessStatus    String
  blockingIssueCount Int
  reviewWarningCount Int
  legacyMetadataOnly Boolean  @default(false)
  createdAt          DateTime @default(now())

  company  Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user     User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  artifact SignedReportArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([artifactId])
  @@index([reportYear])
  @@index([createdAt])
  @@map("signed_annual_fgas_reports")
}

model Feedback {
  id          String       @id @default(cuid())
  companyId   String?
  userId      String?
  type        FeedbackType
  title       String
  description String
  pageUrl     String?
  createdAt   DateTime     @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("feedback")
}
